# Brightuity — Environment variable template
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real keys where marked <your-key-here>
#   3. Never commit .env — it is in .gitignore
#   4. In production (Docker / Vultr), inject these as environment variables
#      directly; do not ship a .env file to the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI/ML API ─────────────────────────────────────────────────────────────────
# Used by: Orchestrator, KYC Guardian, Dynamic Compliance
# Get key: https://api.aimlapi.com → Dashboard → API Keys
AIMLAPI_KEY=<your-aimlapi-key-here>

# ── Featherless ───────────────────────────────────────────────────────────────
# Used by: Doc Auditor, Stress-Test Simulator, Asset Tokenizer
# Get key: https://featherless.ai → Dashboard → API Keys
FEATHERLESS_KEY=<your-featherless-key-here>

# ── Band Agent API — backend identity ─────────────────────────────────────────
# The backend acts as a dedicated "Backend Trigger" Band agent.
# Get keys from the Band developer portal → Agent Settings.
# BAND_BACKEND_API_KEY=<api-key-for-the-backend-band-agent>
# BAND_BACKEND_AGENT_ID=<uuid-of-the-backend-band-agent>

# ── Band Agent API — orchestrator ─────────────────────────────────────────────
# BAND_ORCHESTRATOR_AGENT_ID=<uuid-of-the-orchestrator-band-agent>
# BAND_ORCHESTRATOR_HANDLE=Orchestrator              # @handle used in trigger message

# ── Band Agent API — specialist agents (UUIDs for room participant seeding) ───
# BAND_KYC_AGENT_ID=<uuid-of-kyc-guardian-band-agent>
# BAND_COMPLIANCE_AGENT_ID=<uuid-of-dynamic-compliance-band-agent>
# BAND_DOCAUDITOR_AGENT_ID=<uuid-of-doc-auditor-band-agent>
# BAND_STRESSTEST_AGENT_ID=<uuid-of-stress-test-band-agent>
# BAND_TOKENIZER_AGENT_ID=<uuid-of-asset-tokenizer-band-agent>
# BAND_CONSENSUS_AGENT_ID=<uuid-of-consensus-signer-band-agent>
# BAND_GOVERNANCE_AGENT_ID=<uuid-of-governance-audit-band-agent>

# ── Band Agent API — connectivity ─────────────────────────────────────────────
# THENVOI_REST_URL=https://app.band.ai                # Band base URL (no trailing slash)
# BAND_BRIDGE_POLL_INTERVAL=5                         # seconds between context polls
# BAND_BRIDGE_TIMEOUT=180                             # max seconds to wait for result

# ── Database — DB1 PostgreSQL (Zone 1, local Docker network) ──────────────────
# DB1_URL=postgresql://brightuity:password@localhost:5432/brightuity_db1

# ── Database — DB2 PostgreSQL (Zone 3, enrichment, inbound-only) ──────────────
# DB2_URL=postgresql://brightuity_ro:password@localhost:5433/brightuity_db2

# ── Auth — JWT secret for the FastAPI backend ─────────────────────────────────
# JWT_SECRET=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">

# ═════════════════════════════════════════════════════════════════════════════
# Docker Compose additions (required when running docker compose up)
# ═════════════════════════════════════════════════════════════════════════════

# ── Zone 1 ─ PostgreSQL PII database ──────────────────────────────────────────
# Used by: db1_pii (docker-compose.yml), pii_seed, pii_gateway, backend
# POSTGRES_USER=brightuity
# POSTGRES_PASSWORD=<strong-random-password>
# POSTGRES_DB=brightuity_pii
# PII_DB_DSN=postgresql://brightuity:<password>@db1_pii:5432/brightuity_pii

# ── Band agent API keys (one pair per agent) ───────────────────────────────────
# Get from Band developer portal → Agent Settings for each registered agent.
# BAND_ORCHESTRATOR_API_KEY=<api-key-for-orchestrator-band-agent>
# BAND_KYC_API_KEY=<api-key-for-kyc-guardian-band-agent>
# BAND_COMPLIANCE_API_KEY=<api-key-for-dynamic-compliance-band-agent>
# BAND_DOCAUDITOR_API_KEY=<api-key-for-doc-auditor-band-agent>
# BAND_STRESSTEST_API_KEY=<api-key-for-stress-test-band-agent>
# BAND_TOKENIZER_API_KEY=<api-key-for-asset-tokenizer-band-agent>

# ── Internal service URLs (compose resolves these by service name) ─────────────
# Set these to the service-name defaults for docker compose; override for dev.
# SIGNER_URL=http://consensus_signer:8700
# SCOPE_SERVICE_URL=http://pii_gateway:8701

# ── Internal service ports (override only if you remap host ports) ─────────────
# SIGNER_PORT=8700
# PII_GW_PORT=8701

# ── Backend persistent storage paths (inside the case_store_data volume) ───────
# CASES_DB_PATH=/app/data/brightuity_cases.db
# AUTH_KEY_PATH=/app/data/auth_private_key.pem
